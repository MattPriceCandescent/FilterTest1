# Scraper credentials and URLs (copy to .env and fill in; never commit .env)
# All values below are placeholders. Use real values only in .env (which is gitignored).
SCRAPE_LOGIN_URL=https://example.com/login
SCRAPE_USER=your_email@example.com
SCRAPE_PASSWORD=your_password
SCRAPE_LIST_URL=https://example.com/listing
# Optional: SCRAPE_BASE_URL (defaults to origin of SCRAPE_LOGIN_URL)
